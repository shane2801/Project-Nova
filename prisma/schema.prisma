// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Get a free hosted Postgres database in seconds: `npx create-db`

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id          Int       @id @default(autoincrement())
  email       String    @unique
  passwordHash String?
  name        String
  rfidTag     String    @unique
  role        String    @default("user")
  department  String?
  jobTitle    String?
  employeeId  String?   @unique
  joinedAt    DateTime?
  privacyAckAt DateTime?
  carMake     String?
  carModel    String?
  carYear     Int?
  carPlate    String?
  bookings    Booking[]
  transfersOut TransferRequest[] @relation("TransferFrom")
  transfersIn  TransferRequest[] @relation("TransferTo")
  createdAt   DateTime  @default(now())
  chargingSessions ChargingSession[]
  maintenanceBlocks   MaintenanceBlock[] @relation("MaintenanceCreatedBy")
  bookingsCreatedByMe Booking[]          @relation("BookingCreatedByAdmin")
  notifications Notification[]
}

model Booking {
  id              Int      @id @default(autoincrement())
  userId          Int
  user            User     @relation(fields: [userId], references: [id])
  stationIdentity String
  connectorId     Int      @default(1)
  startAt         DateTime
  endAt           DateTime
  status          String   @default("reserved")
  carPlate        String?
  carModel        String?
  transferredFromUserId Int?
  simulatedSessionId Int?
  simulatedAt     DateTime?
  transferRequests TransferRequest[]
  createdAt       DateTime @default(now())
  createdByAdminId Int?
  createdByAdmin   User? @relation("BookingCreatedByAdmin", fields: [createdByAdminId], references: [id])
}

model BookingRule {
  key       String   @id
  value     String
  updatedAt DateTime @updatedAt
}

model TransferRequest {
  id         Int      @id @default(autoincrement())
  bookingId  Int
  booking    Booking  @relation(fields: [bookingId], references: [id], onDelete: Cascade)
  fromUserId Int
  fromUser   User     @relation("TransferFrom", fields: [fromUserId], references: [id])
  toUserId   Int
  toUser     User     @relation("TransferTo", fields: [toUserId], references: [id])
  status     String   @default("pending") // pending | accepted | declined | cancelled | expired
  createdAt  DateTime @default(now())
  resolvedAt DateTime?

  @@index([toUserId, status])
  @@index([fromUserId, status])
  @@index([bookingId])
}

model ChargingSession {
  id              Int      @id @default(autoincrement())
  csmsSessionId   Int?     @unique  // null for seeded data
  userId          Int
  user            User     @relation(fields: [userId], references: [id])
  stationIdentity String
  connectorId     Int
  startTime       DateTime
  stopTime        DateTime?
  energyWh        Int      @default(0)
  durationSec     Int      @default(0)
  // Denormalized snapshots so changes to user/vehicle later don't rewrite history
  userNameSnap        String
  userEmailSnap       String
  departmentSnap      String?
  jobTitleSnap        String?
  employeeIdSnap      String?
  carMakeSnap         String?
  carModelSnap        String?
  carYearSnap         Int?
  // Marker so we can distinguish real vs seeded data
  source          String   @default("real") // "real" | "seed"
  createdAt       DateTime @default(now())

  @@index([userId])
  @@index([startTime])
  @@index([stationIdentity])
  @@index([carMakeSnap])
  @@index([departmentSnap])
}

model MaintenanceBlock {
  id              Int      @id @default(autoincrement())
  stationIdentity String
  connectorId     Int
  startAt         DateTime
  endAt           DateTime
  reason          String
  createdByUserId Int
  createdBy       User     @relation("MaintenanceCreatedBy", fields: [createdByUserId], references: [id])
  csmsBlocked     Boolean  @default(false)
  active          Boolean  @default(true)
  createdAt       DateTime @default(now())

  @@index([stationIdentity, connectorId, startAt])
  @@index([active])
}

model Notification {
  id          Int      @id @default(autoincrement())
  userId      Int
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  type        String   // "booking_created" | "booking_cancelled" | "transfer_invited" | "transfer_accepted" | "transfer_declined" | "session_start_soon" | "session_end_soon" | "transfer_cutoff" | "force_stopped" | "admin_user_released" | "admin_user_transferred"
  title       String
  body        String
  data        String?  // JSON blob with bookingId, transferId etc for deep-linking
  readAt      DateTime?
  createdAt   DateTime @default(now())

  @@index([userId, readAt])
  @@index([userId, createdAt])
}